.:53 {
    errors
    health :8080
    ready :8181

    # Serve zones managed by XPanel (auto-detects .zone files)
    auto {
        directory /zones (.*)\.zone
        reload 10s
    }

    # Forward anything not in a local zone to upstream resolvers
    forward . 1.1.1.1 8.8.8.8 {
        policy sequential
        health_check 5s
    }

    cache 30
    log
}
